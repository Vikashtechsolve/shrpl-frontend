zedName":"Increased accessibility","icon":"handicap"},{"code":"elevator","localizedName":"Elevator","icon":"check"},{"code":"adapted_bath","localizedName":"Adapted bath","icon":"check"},{"code":"nosmoke","localizedName":"No smoking","icon":"smoking-na"}]},{"code":"dining","localizedName":"Dining","amenities":[{"code":"special_diet_menus__on_request_","localizedName":"Special diet menus (on request)","icon":"check"},{"code":"snack_bar","localizedName":"Snack bar","icon":"check"},{"code":"restaurant","localizedName":"Restaurant","icon":"restaurant"},{"code":"bar","localizedName":"Bar\u002FLounge","icon":"bar"}]},{"code":"bedroom","localizedName":"Bedroom","amenities":[{"code":"socket_near_the_bed","localizedName":"Socket near the bed","icon":"check"},{"code":"alarm_clock","localizedName":"Alarm clock","icon":"timer"},{"code":"wardrobe_or_closet","localizedName":"Wardrobe or closet","icon":"check"}]},{"code":"outdoor","localizedName":"Outdoor","amenities":[{"code":"terrace\u002Fpatio","localizedName":"Terrace\u002FPatio","icon":"terrace"},{"code":"balcony","localizedName":"Balcony","icon":"city"}]},{"code":"work_space","localizedName":"Workspace","amenities":[{"code":"fax_photocopying","localizedName":"Fax\u002Fphotocopying","icon":"print"},{"code":"laptop_safe","localizedName":"Laptop safe","icon":"laptop"}]},{"code":"family_friendly","localizedName":"Family friendly","amenities":[{"code":"cribrollaway","localizedName":"Cribs available","icon":"check"},{"code":"indoor_play_area","localizedName":"Indoor play area","icon":"playground"}]},{"code":"laundry","localizedName":"Laundry","amenities":[{"code":"laundryroom","localizedName":"Laundry facilities","icon":"laundry"}]},{"code":"fitness","localizedName":"Fitness","amenities":[{"code":"fitnesscenter","localizedName":"Fitness center","icon":"fitness-center"}]}],"count":75},"aboutData":{"highlights":[],"hotelDescription":"\u003Cp\u003EThe Alta Hotels The Snowpine Lodge is located on the top of Little Cottonwood Canyon and nestled in the Wasatch Mountains in Alta, Utah. The hotel is only a 30-minute drive from Big Cottonwood Canyon and less than 35 miles from the Salt Lake City International Airport. This hotel was recently renovated in 2017 and offers 78 air-conditioned, non-smoking guestrooms next to Alta Ski Resort.\u003C\u002Fp\u003E\n\u003Cp\u003ELodging options at The Snowpine Lodge range from dorm living to standard rooms, premium rooms, and suites. The hotel has a fitness center and yoga studio with a rowing machine, free weights, stationary bike, treadmills, ellipticals, and a weight machine. There is a heated outdoor pool along with jetted spas, basketball hoops, and a volleyball net for exercise and fun. The hotel also offers outdoor firepits and ski lockers where guests can stow their gear.\u003C\u002Fp\u003E\n\u003Cp\u003EThere are two dining options at the hotel including Swen’s Restaurant, which offers both communal and family seating. The menu is globally-inspired and makes use of regionally-sourced ingredients. Some of the top dishes include the grilled bone-in pork chop, rigatoni bolognese, and mac and cheese with ham and English peas. The Gulch Pub is also available with handcrafted drinks.\u003C\u002Fp\u003E\n\u003Cp\u003EThe Snowpine Lodge also houses Stillwell Spa where guests can enjoy beauty treatments, massage, waxing, and facials, among other things. There is also a steam room and sauna to enjoy relaxing. Guests preparing for events can make sure of makeup artists and stylists to ensure the day goes off without a hitch.\u003C\u002Fp\u003E","localizedLicenseInfo":null,"facetScores":[]},"locationData":{"mapState":{"home":{"coordinates":{"lat":40.591255,"lng":-111.63239},"name":null,"locationId":null,"distance":null,"address":"","duration":null,"travelMode":null},"locations":[{"coordinates":{"lat":40.580941,"lng":-111.637244},"name":"Alta Ski Area","locationId":"33106","distance":"0.8 mi","address":null,"duration":null,"travelMode":null},{"coordinates":{"lat":4