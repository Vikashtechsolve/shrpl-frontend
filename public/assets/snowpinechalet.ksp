tentUrl":"https:\u002F\u002Fcontent.r9cdn.net\u002Frimg\u002Fhimg\u002Fea\u002Fbe\u002Fa7\u002Fice-133799-73868450_3XL-291965.jpg?width=500&height=350&xhint=1497&yhint=960&crop=true","description":"The Snowpine Lodge - Alta - Bathroom","@type":"ImageObject"},{"contentUrl":"https:\u002F\u002Fcontent.r9cdn.net\u002Frimg\u002Fhimg\u002F85\u002Fc7\u002F67\u002Fexpedia_group-495978-128588266-115977.jpg?width=500&height=350&xhint=540&yhint=333&crop=true","description":"The Snowpine Lodge - Alta","@type":"ImageObject"},{"contentUrl":"https:\u002F\u002Fcontent.r9cdn.net\u002Frimg\u002Fhimg\u002Fea\u002Fbe\u002Fa7\u002Fice-133799-73868544_3XL-426084.jpg?width=500&height=350&xhint=1497&yhint=960&crop=true","description":"The Snowpine Lodge - Alta - Meeting room","@type":"ImageObject"},{"contentUrl":"https:\u002F\u002Fcontent.r9cdn.net\u002Frimg\u002Fhimg\u002Fea\u002Fbe\u002Fa7\u002Fice-133799-73868862_3XL-749169.jpg?width=500&height=350&xhint=1555&yhint=960&crop=true","description":"The Snowpine Lodge - Alta - Property amenity","@type":"ImageObject"}],"image":"https:\u002F\u002Fcontent.r9cdn.net\u002Frimg\u002Fhimg\u002Ff0\u002F84\u002Fbb\u002Fexpedia_group-495978-26cda8fa-748178.jpg?crop=true&width=500&height=350","url":"https:\u002F\u002Fwww.kayak.com\u002FAlta-Hotels-The-Snowpine-Lodge.495978.ksp","description":"Discover a superior four-star mountain experience at the Snowpine. Positioned at the top of Little Cottonwood Canyon and nestled in Utahs Wasatch mountains, the Snowpine shares the mountain with Alta Ski Resort, offering unrivaled access to the worlds best mountain recreation. At Altas finest year-round luxury hotel, guests can rejuvenate at Stillwell Spa, indulge in a fine meal at Swens or relax in the plush comfort of our guest rooms, all while keeping the mountains within view.","telephone":"","aggregateRating":{"ratingValue":"8.5","bestRating":"10","ratingCount":"67","@type":"AggregateRating"},"priceRange":"$194 per night (Latest starting price for this hotel)","address":{"streetAddress":"10420 Little Cottonwood Canyon Road","addressLocality":"Alta","postalCode":"84092","addressRegion":"Utah","addressCountry":"United States","@type":"PostalAddress"},"amenityFeature":["Spa and wellness center","Free Wi-Fi","Radio","Business center","Wi-Fi available in all areas","Internet","Terrace\u002FPatio","Increased accessibility","Fax\u002Fphotocopying","Family rooms","Safety deposit box","Cribs available","Gift shop","Laundry facilities","Elevator","Flat-screen TV","Meeting\u002FBanquet facilities","Hiking","Free toiletries","Shampoo","Heated pool","Shared lounge\u002FTV area","Ski equipment rental (on site)","Ski pass vendor","Heating","Shower","Shower cap","Special diet menus (on request)","Game room","Adapted bath","Slippers","Additional bathroom","Hot tub","Snack bar","Outdoor pool","Socket near the bed","Additional toilet","Skiing","Evening entertainment","Alarm clock","No smoking","Balcony","Bathtub","Restaurant","Bar\u002FLounge","Laptop safe","Parking","Body soap","Hairdryer","Fitness center","Lockers","Indoor play area","Cable or satellite TV","Telephone","Carpeted","Mountain view","Air-conditioned","Toilet","Toilet paper","Sauna","Airport shuttle","TV","Table tennis","Conditioner","Valet parking","Pool with a view","Pool table","Ski-in\u002FSki-out","Bathrobe","Private bathroom","Ski storage","Wardrobe or closet","24hr front desk","Private parking","Shuttle service (additional charge)"],"name":"The Snowpine Lodge","alternateName":["The Snowpine Lodge Alta","The Snowpine Lodge Alta, Utah","The Snowpine Lodge SLC","The Snowpine Lodge Hotel","The Snowpine Lodge Hotel Alta"],"@type":"Hotel","@context":"http:\u002F\u002Fschema.org"},"officialWebsite":null,"filterNames":[],"searchFormContainerData":{"hotelName":"The Snowpine Lodge","starCount":0,"useStarRating":false,"address":"\u003Cspan\u003EAlta, UT\u003C\u002Fspan\u003E \u003Cspan\u003E84092\u003C\u002Fspan\u003E, \u003Cspan\u003EUnited States\u003C\u002Fspan\u003E","secondaryAddress":"","phone":"","shortAddress":"Alta, UT"},"breadcrumbs":[{"title":"KAYAK.com","href":"\u002F","nofollow":false},{"title":"Hotels","href":"\u002Fhotels","nofollow":false},{"title":"North America Hotels","href":"\u002FCheap-Hotels-in-North-America.na.htc.html","nofollow":false},{"title":"Hotels in the United States","href":"\u002FUnited-States-Hotels.253.dc.html","nofollow":false},{"title":"Hotels in Utah","href":"\u002FUtah-United-States-Hotels.162.dr.html","nofollow":false},{"title":"Alta Hotels","href":"\u002FAlta-Hotels.40612.hotel.ksp","nofollow":false},{"title":"The Snowpine Lodge","href":"\u002FAlta-Hotels-The-Snowpine-Lodge.495978.ksp","nofollow":false}],"locationNames":{"localizedLocationName":"Alta","localizedCityName":"Alta"},"emergencyWarning":{},"hotelDescription":"\u003Cp\u003EThe Alta Hotels The Snowpine Lodge is located on the top of Little Cottonwood Canyon and nestled in the Wasatch Mountains in Alta, Utah. The hotel is only a 30-minute drive from Big Cottonwood Canyon and less than 35 miles from the Salt Lake City International Airport. This hotel was recently renovated in 2017 and offers 78 air-conditioned, non-smoking guestrooms next to Alta Ski Resort.\u003C\u002Fp\u003E\n \n \u003Cp\u003ELodging options at The Snowpine Lodge range from dorm living to standard rooms, premium rooms, and suites. The hotel has a fitness center and yoga studio with a rowing machine, free weights, stationary bike, treadmills, ellipticals, and a weight machine. There is a heated outdoor pool along with jetted spas, basketball hoops, and a volleyball net for exercise and fun. The hotel also offers outdoor firepits and ski lockers where guests can stow their gear.\u003C\u002Fp\u003E\n \n \u003Cp\u003EThere are two dining options at the hotel including Swen’s Restaurant, which offers both communal and family seating. The menu is globally-inspired and makes use of regionally-sourced ingredients. Some of the top dishes include the grilled bone-in pork chop, rigatoni bolognese, and mac and cheese with ham and English peas. The Gulch Pub is also available with handcrafted drinks.\u003C\u002Fp\u003E\n \n \u003Cp\u003EThe Snowpine Lodge also houses Stillwell Spa where guests can enjoy beauty treatments, massage, waxing, and facials, among other things. There is also a steam room and sauna to enjoy relaxing. Guests preparing for events can make sure of makeup artists and stylists to ensure the day goes off without a hitch.\u003C\u002Fp\u003E","searchUrlParameters":[],"isAwardsBadgeEnabled":false,"isCore":false,"seoPageType":"HotelDetail","reviewsData":{"overallScore":85,"scoreByTravellerType":{},"scoreByFacet":{},"reviewCountByTravellerType":{"families":16,"friends":9,"solo":16,"couples":24},"prosSentimentsWithCount":[{"sentiment":"\"Great location, fantastic vibe, and a real mix of travellers.\"","additionalSentiments":[],"count":1},{"sentiment":"\"The Lodge caters properly for families, singles and couples.\"","additionalSentiments":[],"count":1},{"sentiment":"Awesome food!","additionalSentiments":["\"So thoughtful, and the food was excellent\"","Cozy and comfortable with excellent food and friendly staff.","\"Amazing staff, very convenient ski in ski out and really good food.\""],"count":4}],"consSentimentsWithCount":[{"sentiment":"\"Dave, the manager, personally stepped in to sort out a problem.\"","additionalSentiments":["Nothing was too much trouble."],"count":2},{"sentiment":"Nothing was too much trouble.","additionalSentiments":[],"count":1},{"sentiment":"Nothing to not like.","additionalSentiments":["Nothing was too much trouble."],"count":2}],"reviews":[{"id":"dYmC_nUBg_-V3a0CAEiv","localizedMonthYear":"Mar 2017","score":100,"localizedRatingCategory":"Excellent","positiveComment":"Convenience, Dinners were great, staff was warm and helpful. Very pleased. Stayined in the dorms with friends.","author":"Rayne","siteName":"KAYAK","siteLogo":"\u002Fprovider-logos\u002Fhotels\u002Freviews\u002Fh\u002FkayakLogo.png","internal":true,"localizedScore":"100.0"}],"totalReviewAmount":67,"reviewTags":[{"tag":"excellent staff","count":39},{"tag":"good food","count":18},{"tag":"great location","count":9},{"tag":"nothing was too much","count":7},{"tag":"lodge","count":6},{"tag":"families singles","count":4},{"tag":"go beyond","count":4},{"tag":"nothing was too much trouble","count":4},{"tag":"teething problems","count":4},{"tag":"wood beams","count":4},{"tag":"mix of travellers","count":2}],"reviewCountByTravellerRating":[]},"reviewsScoreDistribution":[{"ratingBucket":{"key":"6","min":0,"max":40},"count":2},{"ratingBucket":{"key":"5","min":40,"max":50},"count":0},{"ratingBucket":{"key":"4","min":50,"max":60},"count":1},{"ratingBucket":{"key":"3","min":60,"max":70},"count":3},{"ratingBucket":{"key":"2","min":70,"max":80},"count":2},{"ratingBucket":{"key":"1","min":80,"max":90},"count":14},{"ratingBucket":{"key":"0","min":90,"max":101},"count":45}],"reviewsScoreDistributionBySource":[{"reviewSource":{"providerId":"BOOKING","providerName":"Booking.com","providerLogo":"\u002Fprovider-logos\u002Fhotels\u002Freviews\u002Fh\u002FbookingLogo.png"},"count":1,"totalCount":66,"avgScore":85},{"reviewSource":{"providerId":"KAYAK","providerName":"KAYAK","providerLogo":"\u002Fprovider-logos\u002Fhotels\u002Freviews\u002Fh\u002FkayakLogo.png"},"count":1,"totalCount":1,"avgScore":100}],"links":{"linkhubOtherDestinationsLinks":[{"href":"\u002FDes-Moines-Hotels.10170.hotel.ksp","title":"Des Moines Hotels","isFallbackLink":false},{"href":"\u002FBoone-Hotels.8678.hotel.ksp","title":"Boone Hotels","isFallbackLink":false},{"href":"\u002FPaso-Robles-Hotels.12273.hotel.ksp","title":"Paso Robles Hotels","isFallbackLink":false},{"href":"\u002FOcean-Shores-Hotels.16415.hotel.ksp","title":"Ocean Shores Hotels","isFallbackLink":false},{"href":"\u002FAnaheim-Hotels.30366.hotel.ksp","title":"Anaheim Hotels","isFallbackLink":false},{"href":"\u002FKingston-Hotels.20407.hotel.ksp","title":"Kingston Hotels","isFallbackLink":false},